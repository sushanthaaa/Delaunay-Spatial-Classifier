# ==============================================================================
# GITIGNORE FOR DELAUNAY TRIANGULATION CLASSIFIER
# ==============================================================================

# ------------------------------------------------------------------------------
# System Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# IDE and Editor
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Python Environment
# ------------------------------------------------------------------------------
venv/
.venv/
env/
.env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/
dist/
*.egg

# ------------------------------------------------------------------------------
# C++ Build Artifacts
# ------------------------------------------------------------------------------
build/
cmake-build-*/
*.o
*.out
*.app
*.dSYM/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

# ------------------------------------------------------------------------------
# Data Files (Large Datasets - Regenerate via scripts)
# ------------------------------------------------------------------------------
data/**/*.csv
!data/train/.gitkeep
!data/test/.gitkeep
data/medmnist/

# ------------------------------------------------------------------------------
# Results (Regenerate via benchmark scripts)
# Keep only summary CSVs, exclude intermediate files
# ------------------------------------------------------------------------------
results/*.csv
results/*.txt
results/*.log
results/logs/
results/figures/

!results/cv_summary.csv
!results/ablation_summary.csv
!results/ablation_dynamic_summary.csv
!results/scalability_train.csv
!results/scalability_inference.csv
!results/bucket_type_distribution.csv
!results/significance_tests.csv

# ------------------------------------------------------------------------------
# Large Binary Files
# ------------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.zip
*.tar.gz

# EXCEPTION: Keep key figures for README
!figures/wine/4_decision_boundaries.png
!figures/earthquake/4_decision_boundaries.png
!figures/spiral/4_decision_boundaries.png
!figures/summary_scalability.png
!figures/summary_dynamic.png

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.log
*.bak
